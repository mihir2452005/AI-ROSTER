      "reaction": "🎬"
    },
    {
      "id": "opn_009",
      "mode": "friendly",
      "personalities": ["sarcastic_friend"],
      "template": "Hey {username}! 👋 I am your {roaster_self} for the next few minutes. Try not to make it awkward for {roaster_pronoun_obj}.",
      "placeholders": {
        "username": { "type": "username" },
        "roaster_self": {
          "type": "roaster",
          "values": ["male:buddy", "female:bestie", "neutral:pal"],
