    {
      "id": "opn_008",
      "mode": "savage",
      "personalities": ["savage_one", "sarcastic_friend"],
      "template": "Well, well, well. {username} decided to show up. {roaster_title}, you picked the wrong day, and I am the wrong {roaster_self}. Let's begin.",
